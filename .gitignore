# Office/LibreOffice lock files
.~lock.*#

# macOS
.DS_Store

# Jupyter
.ipynb_checkpoints/

# Large rendered network figures (each >20MB)
cooccurrence_network_*.png

# Annotation and binning output directories
bakta/
bins_*/
*.zip
kofamscan/*

# Python bytecode
__pycache__/

# MAG FAA outputs (keep tracking the .zip)
mag/*
meta/*
MAG_faas/
MAG_faas.*
mag_16s_mapping_tmp/

# Synthetic per-ASV KBase genomes (~29GB, regenerable via
# prFBA/build_synthetic_genomes_parallel.py). Track only the manifest.
synthetic_genomes/*
!synthetic_genomes/synthetic_genome_manifest.json
# P3 (gene-richest-conspecific tie-break) variant, kept alongside for comparison; track only its manifest.
synthetic_genomes_p3/*
!synthetic_genomes_p3/synthetic_genome_manifest.json

# macOS AppleDouble junk + large local archives (>100MB, can't go to GitHub)
._*
kofamscan.zip

# clade_classify concatenated bin FASTA/FAA (~1.3GB, regenerable; >100MB so
# can't go to GitHub — these were purged once in dc13ce0, keep them untracked)
clade_classify/out/all_bins.fna
clade_classify/out/all_bins_orf.faa

# copyrighted reference PDFs (reading only)
*.pdf
# cloned public reference DB (re-clone: see ppk1_classify/SUMMARY_ppk1.md)
ppk1_classify/ppk1_Database/
