# Office/LibreOffice lock files
.~lock.*#

# macOS
.DS_Store

# Jupyter
.ipynb_checkpoints/

# Large rendered network figures (each >20MB)
cooccurrence_network_*.png

# Annotation and binning output directories
bakta/
bins_*/
*.zip
kofamscan/*

